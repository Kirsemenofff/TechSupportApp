<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Новая заявка"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Опишите проблему"
            android:textColor="@color/secondaryTextColor"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_background"
            android:margin="16dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Название"
                android:textColor="@color/secondaryTextColor"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/titleEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Кратко опишите суть"
                android:background="@drawable/edit_text_background"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:textColor="@color/primaryTextColor"
                android:textColorHint="@color/hintTextColor"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Описание проблемы"
                android:textColor="@color/secondaryTextColor"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/descriptionEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Подробно опишите проблему"
                android:background="@drawable/edit_text_background"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:minLines="3"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textColor="@color/primaryTextColor"
                android:textColorHint="@color/hintTextColor"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Номер аудитории"
                android:textColor="@color/secondaryTextColor"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/roomNumberEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Например: 215"
                android:background="@drawable/edit_text_background"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:textColor="@color/primaryTextColor"
                android:textColorHint="@color/hintTextColor"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Приоритет"
                android:textColor="@color/secondaryTextColor"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/prioritySpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/edit_text_background"
                android:padding="8dp"
                android:paddingStart="12dp"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/attachFileButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Прикрепить файл"
                android:background="@drawable/button_background_dark"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/saveTaskButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Создать заявку"
                android:background="@drawable/button_background"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
